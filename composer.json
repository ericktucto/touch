{
  "name": "erick/touch",
  "description": "Microframework for web applications",
  "type": "library",
  "keywords": [
    "microframework",
    "framework",
    "php",
    "touch",
    "web",
    "applications",
    "rest",
    "api"
  ],
  "license": "MIT",
  "scripts": {
    "lint:php": "vendor/bin/phpcs --standard=PSR12 src/",
    "fix:php": "vendor/bin/phpcbf --standard=PSR12 src/"
  },
  "autoload": {
    "psr-4": {
      "Touch\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Touch\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Erick Tucto",
      "email": "erick@ericktucto.com"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "^8.4",
    "php-di/php-di": "^7.0",
    "illuminate/database": "^10.10",
    "filp/whoops": "^2.15",
    "twig/twig": "^3.0",
    "itsgoingd/clockwork": "^5.1",
    "symfony/var-dumper": "^6.2",
    "guzzlehttp/psr7": "^2.5",
    "league/event": "^3.0",
    "league/route": "^5.1",
    "symfony/yaml": "^6.2",
    "hassankhan/config": "^3.1",
    "lune/http-emitter": "^0.0",
    "vlucas/valitron": "^1.4",
    "nyholm/psr7": "^1.8",
    "psr/http-message": "^1.1",
    "http-interop/http-factory-guzzle": "^1.2.1"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "sirbrillig/phpcs-variable-analysis": "^2.0",
    "phpunit/phpunit": "^12",
    "friendsofphp/php-cs-fixer": "^3.94",
    "helmich/phpunit-json-assert": "^3.5",
    "vimeo/psalm": "^6.16"
  }
}
